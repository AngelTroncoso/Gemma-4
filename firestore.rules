rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "angelgabrieltroncoso2019@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 50 &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }
    
    function isValidPost(data) {
      return data.keys().hasAll(['authorUid', 'content', 'createdAt']) &&
             data.authorUid == request.auth.uid &&
             data.content is string && data.content.size() < 1000 &&
             data.content.size() > 0;
    }

    // Profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }
    
    // Posts
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin()) && isValidPost(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }
  }
}
