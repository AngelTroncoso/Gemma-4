{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information for the community.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "displayName": { "type": "string", "description": "Public name" },
        "photoURL": { "type": "string", "description": "Avatar URL" },
        "bio": { "type": "string", "description": "Short bio" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" }
      },
      "required": ["uid", "displayName"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared by a user in the community.",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string", "description": "Author's UID" },
        "authorName": { "type": "string", "description": "Author's display name" },
        "authorPhoto": { "type": "string", "description": "Author's photo URL" },
        "content": { "type": "string", "description": "Post content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "likes": { "type": "number", "description": "Number of likes" }
      },
      "required": ["authorUid", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts."
    }
  }
}
